        "justifyMode": "auto"
      },
      "pluginVersion": "11.1.4",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum(agglayer_certificate_duration_seconds_count{job=\"agglayer\", network_id=~\"$network_id\"})",
          "legendFormat": "settled",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Certificates settled",
      "type": "stat"
    },
