          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum by (network_id, stage) (increase(agglayer_certificate_stage_duration_seconds_count{job=\"agglayer\", network_id=~\"$network_id\"}[$__rate_interval])) > 0",
          "legendFormat": "net {{network_id}} · {{stage}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Certificate stage completions over time",
      "type": "timeseries"
    },
