    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Cumulative count of settled certificates per network (climbs by 1 each time a certificate settles).",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisPlacement": "auto"
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "agglayer_certificate_duration_seconds_count{job=\"agglayer\", network_id=~\"$network_id\"}",
          "legendFormat": "net {{network_id}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Certificates settled (cumulative, per network)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Average time a certificate takes end to end, Pending -> Settled (mean over certificates settled in each window). Y axis = seconds, X axis = time. Legend shows the mean and latest value.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "auto",
            "pointSize": 6,
            "spanNulls": true,
            "axisPlacement": "auto",
            "axisLabel": "seconds"
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum(rate(agglayer_certificate_duration_seconds_sum{job=\"agglayer\", network_id=~\"$network_id\"}[$__rate_interval])) / sum(rate(agglayer_certificate_duration_seconds_count{job=\"agglayer\", network_id=~\"$network_id\"}[$__rate_interval]))",
          "legendFormat": "avg bridging time",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Avg end-to-end bridging time (Pending -> Settled)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Average seconds a certificate spends in each stage (all-time mean), per network. Shown as a table so every value is exact and readable regardless of magnitude: pending (awaiting proof) and proven (settlement-job submission) are typically sub-second; candidate (L1 inclusion + confirmation) is tens of seconds.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "align": "auto", "cellOptions": { "type": "color-text" } },
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": null } ] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "network" },
            "properties": [ { "id": "unit", "value": "short" }, { "id": "custom.cellOptions", "value": { "type": "auto" } } ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 14 },
      "id": 7,
      "options": {
        "showHeader": true,
        "cellHeight": "md",
        "footer": { "show": false },
        "sortBy": []
      },
      "pluginVersion": "11.1.4",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "refId": "pending",
          "editorMode": "code",
          "format": "table",
          "instant": true,
          "range": false,
          "expr": "sum by (network_id) (agglayer_certificate_stage_duration_seconds_sum{job=\"agglayer\", network_id=~\"$network_id\", stage=\"pending\"}) / clamp_min(sum by (network_id) (agglayer_certificate_stage_duration_seconds_count{job=\"agglayer\", network_id=~\"$network_id\", stage=\"pending\"}), 1)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "refId": "proven",
          "editorMode": "code",
          "format": "table",
          "instant": true,
          "range": false,
          "expr": "sum by (network_id) (agglayer_certificate_stage_duration_seconds_sum{job=\"agglayer\", network_id=~\"$network_id\", stage=\"proven\"}) / clamp_min(sum by (network_id) (agglayer_certificate_stage_duration_seconds_count{job=\"agglayer\", network_id=~\"$network_id\", stage=\"proven\"}), 1)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "refId": "candidate",
          "editorMode": "code",
          "format": "table",
          "instant": true,
          "range": false,
          "expr": "sum by (network_id) (agglayer_certificate_stage_duration_seconds_sum{job=\"agglayer\", network_id=~\"$network_id\", stage=\"candidate\"}) / clamp_min(sum by (network_id) (agglayer_certificate_stage_duration_seconds_count{job=\"agglayer\", network_id=~\"$network_id\", stage=\"candidate\"}), 1)"
        }
      ],
      "transformations": [
        { "id": "joinByField", "options": { "byField": "network_id", "mode": "outer" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Time #pending": true, "Time #proven": true, "Time #candidate": true },
            "indexByName": { "network_id": 0, "Value #pending": 1, "Value #proven": 2, "Value #candidate": 3 },
            "renameByName": {
              "network_id": "network",
              "Value #pending": "pending",
              "Value #proven": "proven",
              "Value #candidate": "candidate"
            }
          }
        }
      ],
      "title": "Average time per stage, per network",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Rate of certificates reaching Settled, per network. Continuous line: windows with no settlement are interpolated (dots mark actual settlement events) rather than dropping to zero.",
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "always",
            "pointSize": 6,
            "spanNulls": true,
