        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum by (network_id) (rate(agglayer_certificate_stage_duration_seconds_count{job=\"agglayer\", network_id=~\"$network_id\", stage=\"candidate\"}[$__rate_interval])) > 0",
          "legendFormat": "net {{network_id}} settled/s",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Certificate settle throughput",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Certificate stage completions over time (per network / stage). Continuous line connecting completion events; dots mark actual completions, gaps with no activity are interpolated rather than dropping to zero.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
